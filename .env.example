# Copy to .env if your tooling loads it; docker-compose.yml sets these for `web` by default.

# PostgreSQL (Compose service `db`; DB name matches `config/database.yml` → app_development)
# DATABASE_URL=postgres://budinfo:budinfo_dev_password@db:5432/app_development

# Rails
# RAILS_ENV=development

# pgAdmin 4 (docker compose service `pgadmin` → http://localhost:5050)
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=pgadmin_dev_password
# PGADMIN_PORT=5050

# Optional: seed admin user (db/seeds.rb) — default password is insecure; override in production.
# ADMIN_SEED_PASSWORD=

# Production-style secrets (set on host / PaaS only — never commit real values)
# RAILS_MASTER_KEY=
# SECRET_KEY_BASE=
