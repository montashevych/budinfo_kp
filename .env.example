# Copy to `.env` in the project root. The `web` service uses `env_file: .env` so these reach Rails.
# If `.env` is missing, run: `copy NUL .env` (Windows) or `touch .env` (Unix) before `docker compose up`.

# PostgreSQL (Compose service `db`; DB name matches `config/database.yml` → app_development)
# DATABASE_URL=postgres://budinfo:budinfo_dev_password@db:5432/app_development

# Rails
# RAILS_ENV=development
# DEV_URL_OPTIONS_HOST=localhost
# DEV_URL_OPTIONS_PORT=3000
# RAILS_LOG_LEVEL=debug

# Mail (Phase D.3): customer confirmation + optional shop alert after checkout
# Without SMTP_ADDRESS, development uses :test — nothing is sent to the internet (only ActionMailer::Base.deliveries).
#
# Gmail (sending): App Password + 2FA on the Google account. Use the same address for MAILER_FROM and SMTP_USERNAME
# unless you configure “Send mail as” in Gmail. Quote the app password if it contains spaces:
#   MAILER_FROM="My Shop <you@gmail.com>"
#   SMTP_ADDRESS=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
#
# MAILER_FROM=noreply@yourdomain.com
# SHOP_NOTIFICATION_EMAIL=orders@yourdomain.com
# Production also: MAILER_HOST=yourdomain.com MAILER_PROTOCOL=https
# SMTP_ADDRESS=smtp.example.com SMTP_PORT=587 SMTP_USERNAME=… SMTP_PASSWORD=…

# pgAdmin 4 (docker compose service `pgadmin` → http://localhost:5050)
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=pgadmin_dev_password
# PGADMIN_PORT=5050

# Optional: seed admin user (db/seeds.rb) — default password is insecure; override in production.
# ADMIN_SEED_PASSWORD=

# Production TLS (reverse proxy): defaults on; set RAILS_FORCE_SSL=false only for plain-HTTP smoke tests.
# RAILS_ASSUME_SSL=true
# RAILS_FORCE_SSL=true

# Production-style secrets (set on host / PaaS only — never commit real values)
# RAILS_MASTER_KEY=
# SECRET_KEY_BASE=
