<% content_for :title, @category.display_name %>

<div class="max-w-6xl">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <%= link_to t("categories.index.heading"), categories_path %>
    <span class="mx-2 text-ink-subtle" aria-hidden="true">/</span>
    <span class="font-medium text-ink"><%= @category.display_name %></span>
  </nav>

  <h1 class="mt-4 section-heading-lg"><%= @category.display_name %></h1>

  <%= render "products/grid", products: @products %>
</div>
