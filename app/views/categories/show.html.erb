<% content_for :title, @category.display_name %>

<div class="max-w-5xl">
  <nav class="text-sm text-stone-500" aria-label="breadcrumb">
    <%= link_to t("categories.index.heading"), categories_path, class: "hover:text-stone-800" %>
    <span class="mx-2" aria-hidden="true">/</span>
    <span class="text-stone-900"><%= @category.display_name %></span>
  </nav>

  <h1 class="mt-4 text-3xl font-semibold tracking-tight text-stone-900"><%= @category.display_name %></h1>

  <%= render "products/grid", products: @products %>
</div>
