<% content_for :title, t("categories.index.title") %>

<div class="max-w-6xl">
  <h1 class="section-heading-lg"><%= t("categories.index.heading") %></h1>
  <p class="section-lead"><%= t("categories.index.intro") %></p>
  <p class="mt-3 text-sm text-ink-muted">
    <%= link_to t("nav.products"), products_path, class: "font-semibold text-brand transition hover:text-brand-hover" %>
  </p>

  <ul class="mt-10 grid gap-6 sm:grid-cols-2">
    <% @categories.each do |category| %>
      <li class="card p-6 transition-shadow hover:shadow-card-hover">
        <%= link_to category.display_name, category_path(category), class: "text-lg font-bold text-ink transition hover:text-brand" %>
        <% if category.children.any? %>
          <ul class="mt-4 space-y-2 border-t border-border pt-4">
            <% category.children.ordered.each do |child| %>
              <li>
                <%= link_to child.display_name, category_path(child), class: "text-sm font-medium text-ink-muted transition hover:text-brand" %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </li>
    <% end %>
  </ul>

  <% if @categories.empty? %>
    <p class="mt-10 text-ink-muted"><%= t("categories.index.empty") %></p>
  <% end %>
</div>
