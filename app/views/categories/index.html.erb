<% content_for :title, t("categories.index.title") %>

<div class="max-w-5xl">
  <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= t("categories.index.heading") %></h1>
  <p class="mt-2 text-stone-600"><%= t("categories.index.intro") %></p>
  <p class="mt-2 text-sm text-stone-600">
    <%= link_to t("nav.products"), products_path, class: "font-medium text-stone-900 underline hover:text-stone-600" %>
  </p>

  <ul class="mt-10 grid gap-6 sm:grid-cols-2">
    <% @categories.each do |category| %>
      <li class="rounded-xl border border-stone-200 bg-white p-6 shadow-sm">
        <%= link_to category.display_name, category_path(category), class: "text-lg font-semibold text-stone-900 hover:text-stone-600" %>
        <% if category.children.any? %>
          <ul class="mt-4 space-y-2 border-t border-stone-100 pt-4">
            <% category.children.ordered.each do |child| %>
              <li>
                <%= link_to child.display_name, category_path(child), class: "text-sm font-medium text-stone-600 hover:text-stone-900" %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </li>
    <% end %>
  </ul>

  <% if @categories.empty? %>
    <p class="mt-10 text-stone-500"><%= t("categories.index.empty") %></p>
  <% end %>
</div>
