<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : t("layouts.application.title") %></title>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen bg-stone-50 text-stone-900 antialiased">
    <main class="mx-auto flex max-w-lg flex-col gap-6 px-4 py-20">
      <%= yield %>
      <p>
        <%= link_to t("errors.back_home"), root_path, class: "font-medium text-stone-800 underline" %>
      </p>
    </main>
  </body>
</html>
