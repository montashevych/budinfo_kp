<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t('layouts.application.title') %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png" sizes="148x148">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-screen flex-col bg-surface-page text-ink antialiased">
    <div id="cart-toast" class="pointer-events-none fixed right-4 top-20 z-[60] flex w-[min(100%-2rem,20rem)] flex-col gap-2 md:right-6 md:top-24" aria-live="polite"></div>

    <div class="flex flex-1 flex-col" data-controller="mobile-menu">
      <%= render "shared/header" %>

      <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-10 md:py-12">
        <% if notice.present? %>
          <p class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900" role="status"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert"><%= alert %></p>
        <% end %>
        <%= yield %>
      </main>
    </div>

    <%= render "shared/footer" %>
  </body>
</html>
