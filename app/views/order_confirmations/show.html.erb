<% content_for :title, t("order_confirmations.title") %>

<div class="max-w-2xl">
  <h1 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("order_confirmations.heading") %></h1>
  <p class="mt-2 text-sm text-stone-600"><%= t("order_confirmations.intro", email: @order.email) %></p>

  <dl class="mt-8 space-y-2 rounded-lg border border-stone-200 bg-white p-4 text-sm">
    <div class="flex justify-between gap-4">
      <dt class="text-stone-500"><%= t("order_confirmations.number") %></dt>
      <dd class="font-mono text-stone-900">#<%= @order.id %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-stone-500"><%= Order.human_attribute_name(:status) %></dt>
      <dd class="text-stone-900"><%= t("activerecord.enums.order.status.#{@order.status}", default: @order.status.humanize) %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-stone-500"><%= t("carts.total") %></dt>
      <dd class="font-semibold tabular-nums text-stone-900"><%= number_to_currency(@order.total, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></dd>
    </div>
  </dl>

  <h2 class="mt-8 text-sm font-semibold text-stone-900"><%= t("order_confirmations.items") %></h2>
  <ul class="mt-3 divide-y divide-stone-100 rounded-lg border border-stone-200 bg-white">
    <% @order.order_items.each do |item| %>
      <li class="flex justify-between gap-4 p-3 text-sm">
        <span class="text-stone-800"><%= item.product.display_title %> × <%= item.quantity %></span>
        <span class="shrink-0 tabular-nums text-stone-600"><%= number_to_currency(item.quantity * item.unit_price, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></span>
      </li>
    <% end %>
  </ul>

  <h2 class="mt-8 text-sm font-semibold text-stone-900"><%= t("order_confirmations.shipping") %></h2>
  <div class="mt-2 rounded-lg border border-stone-200 bg-white p-4 text-sm text-stone-700 whitespace-pre-wrap"><%= @order.shipping_name %>
<%= @order.shipping_phone %>
<%= @order.shipping_address %></div>

  <p class="mt-8">
    <%= link_to t("order_confirmations.continue"), root_path, class: "text-sm font-medium text-stone-900 underline" %>
  </p>
</div>
