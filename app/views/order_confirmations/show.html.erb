<% content_for :title, t("order_confirmations.title") %>

<div class="max-w-2xl">
  <div class="rounded-2xl border border-emerald-200 bg-emerald-50/80 px-4 py-3 text-emerald-900 sm:px-5">
    <h1 class="section-heading-md text-emerald-950"><%= t("order_confirmations.heading") %></h1>
    <p class="mt-2 text-sm text-emerald-900/90"><%= t("order_confirmations.intro", email: @order.email) %></p>
  </div>

  <dl class="card mt-8 space-y-3 p-5 text-sm">
    <div class="flex justify-between gap-4">
      <dt class="text-ink-muted"><%= t("order_confirmations.number") %></dt>
      <dd class="font-mono font-medium text-ink">#<%= @order.id %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-ink-muted"><%= Order.human_attribute_name(:status) %></dt>
      <dd class="font-medium text-ink"><%= t("activerecord.enums.order.status.#{@order.status}", default: @order.status.humanize) %></dd>
    </div>
    <div class="flex justify-between gap-4">
      <dt class="text-ink-muted"><%= t("carts.total") %></dt>
      <dd class="font-bold tabular-nums text-brand"><%= number_to_currency(@order.total, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></dd>
    </div>
  </dl>

  <h2 class="mt-8 text-sm font-bold uppercase tracking-wide text-ink-subtle"><%= t("order_confirmations.items") %></h2>
  <ul class="mt-3 divide-y divide-border overflow-hidden rounded-xl border border-border bg-surface-card">
    <% @order.order_items.each do |item| %>
      <li class="flex justify-between gap-4 p-4 text-sm">
        <span class="text-ink"><%= item.product.display_title %> × <%= item.quantity %></span>
        <span class="shrink-0 tabular-nums font-medium text-ink-muted"><%= number_to_currency(item.quantity * item.unit_price, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></span>
      </li>
    <% end %>
  </ul>

  <h2 class="mt-8 text-sm font-bold uppercase tracking-wide text-ink-subtle"><%= t("order_confirmations.shipping") %></h2>
  <div class="card mt-2 whitespace-pre-wrap p-4 text-sm text-ink-muted"><%= @order.shipping_name %>
<%= @order.shipping_phone %>
<%= @order.shipping_address %></div>

  <p class="mt-8">
    <%= link_to t("order_confirmations.continue"), root_path, class: "btn-primary inline-flex" %>
  </p>
</div>
