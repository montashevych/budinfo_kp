<%# locals: (message:, variant: :success) %>
<% if variant == :success %>
  <div role="status" data-controller="cart-toast" class="cart-toast-enter pointer-events-auto rounded-xl border border-emerald-500/30 bg-emerald-950/90 px-4 py-3 text-sm font-medium text-emerald-50 shadow-lg backdrop-blur-sm">
    <%= message %>
  </div>
<% else %>
  <div role="alert" data-controller="cart-toast" class="cart-toast-enter pointer-events-auto rounded-xl border border-amber-500/40 bg-amber-950/90 px-4 py-3 text-sm font-medium text-amber-50 shadow-lg backdrop-blur-sm">
    <%= message %>
  </div>
<% end %>
