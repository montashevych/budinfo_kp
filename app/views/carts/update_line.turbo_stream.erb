<%= render partial: "carts/cart_nav_stream", formats: [ :html ], locals: { count: @cart_count } %>

<% if @update_result == :ok %>
  <%= turbo_stream.update "cart-page-body" do %>
    <%= render partial: "carts/page_body", formats: [ :html ] %>
  <% end %>
  <%= turbo_stream.append "cart-toast" do %>
    <%= render "carts/toast", message: t("carts.updated"), variant: :success %>
  <% end %>
<% else %>
  <% msg = case @update_result
           when :out_of_stock then t("carts.out_of_stock")
           else t("carts.unavailable")
           end %>
  <%= turbo_stream.append "cart-toast" do %>
    <%= render "carts/toast", message: msg, variant: :alert %>
  <% end %>
<% end %>

<% product = Product.with_attached_images.find_by(id: @product_id) %>
<% if product %>
  <%= turbo_stream.replace "add-to-cart-product-#{product.id}" do %>
    <%= render "products/add_to_cart", product: product %>
  <% end %>
<% end %>
