<div class="max-w-5xl">
  <nav class="text-sm text-stone-500" aria-label="breadcrumb">
    <%= link_to t("meta.titles.home"), root_path, class: "hover:text-stone-800" %>
    <span class="mx-2" aria-hidden="true">/</span>
    <span class="text-stone-900"><%= @promotion.title %></span>
  </nav>

  <% if @promotion.image.attached? %>
    <div class="mt-8 overflow-hidden rounded-lg border border-stone-200 bg-stone-50">
      <div class="aspect-[21/9] w-full max-h-[min(28rem,50vh)] md:aspect-[2/1]">
        <%= image_tag product_variant_image_path(@promotion.image, [1600, 900]),
              class: "h-full w-full object-cover object-center",
              loading: "eager",
              decoding: "async",
              alt: @promotion.title %>
      </div>
    </div>
  <% end %>

  <div class="mt-8">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= @promotion.title %></h1>
    <% if @promotion.teaser.present? %>
      <p class="mt-3 text-lg text-stone-600 leading-relaxed"><%= @promotion.teaser %></p>
    <% end %>
    <% if @promotion.body.present? %>
      <div class="mt-6 text-stone-700 leading-relaxed [&_p+p]:mt-4">
        <%= simple_format @promotion.body %>
      </div>
    <% end %>
  </div>

  <p class="mt-10">
    <%= link_to t("errors.back_home"), root_path, class: "text-sm font-medium text-stone-700 underline decoration-stone-300 underline-offset-4 hover:text-stone-900" %>
  </p>
</div>
