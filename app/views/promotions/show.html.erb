<div class="max-w-6xl">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <%= link_to t("meta.titles.home"), root_path %>
    <span class="mx-2 text-ink-subtle" aria-hidden="true">/</span>
    <span class="font-medium text-ink"><%= @promotion.title %></span>
  </nav>

  <% if @promotion.image.attached? %>
    <div class="mt-8 overflow-hidden rounded-2xl border border-border bg-surface-muted shadow-card">
      <div class="home-promo-media-box overflow-hidden">
        <%= image_tag product_variant_image_path(@promotion.image, [1500, 1000]),
              class: "absolute inset-0 h-full w-full object-cover object-center",
              loading: "eager",
              decoding: "async",
              alt: @promotion.title %>
      </div>
    </div>
  <% end %>

  <div class="mt-8 max-w-3xl">
    <h1 class="section-heading-lg leading-snug"><%= @promotion.title %></h1>
    <% if @promotion.teaser.present? %>
      <p class="mt-3 text-lg leading-relaxed text-ink-muted"><%= @promotion.teaser %></p>
    <% end %>
    <% if @promotion.body.present? %>
      <div class="mt-6 text-base leading-relaxed text-ink-muted [&_p+p]:mt-4">
        <%= simple_format @promotion.body %>
      </div>
    <% end %>
  </div>

  <p class="mt-10">
    <%= link_to t("errors.back_home"), root_path, class: "btn-secondary inline-flex" %>
  </p>
</div>
