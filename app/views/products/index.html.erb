<% content_for :title, t("products.index.title") %>

<div class="max-w-5xl">
  <nav class="text-sm text-stone-500" aria-label="breadcrumb">
    <%= link_to t("categories.index.heading"), categories_path, class: "hover:text-stone-800" %>
    <span class="mx-2" aria-hidden="true">/</span>
    <span class="text-stone-900"><%= t("products.index.heading") %></span>
  </nav>

  <h1 class="mt-4 text-3xl font-semibold tracking-tight text-stone-900"><%= t("products.index.heading") %></h1>
  <p class="mt-2 text-stone-600"><%= t("products.index.intro") %></p>

  <%= form_with url: products_path, method: :get, local: true, class: "mt-8 flex flex-col gap-4 rounded-xl border border-stone-200 bg-white p-4 shadow-sm sm:flex-row sm:flex-wrap sm:items-end" do %>
    <div class="flex flex-col gap-1">
      <%= label_tag :category_id, t("products.index.filter_category"), class: "text-sm font-medium text-stone-700" %>
      <%= select_tag :category_id,
            options_for_select(
              [[t("products.index.any_category"), ""]] + @filter_categories.flat_map { |c|
                [[c.display_name, c.id.to_s]] + c.children.ordered.map { |ch| ["— #{ch.display_name}", ch.id.to_s] }
              },
              params[:category_id]
            ),
            class: "rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-stone-900 shadow-sm focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= label_tag :min_price, t("products.index.filter_min_price"), class: "text-sm font-medium text-stone-700" %>
      <%= number_field_tag :min_price, params[:min_price], min: 0, step: 0.01, class: "w-full rounded-md border border-stone-300 px-3 py-2 text-sm sm:w-36" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= label_tag :max_price, t("products.index.filter_max_price"), class: "text-sm font-medium text-stone-700" %>
      <%= number_field_tag :max_price, params[:max_price], min: 0, step: 0.01, class: "w-full rounded-md border border-stone-300 px-3 py-2 text-sm sm:w-36" %>
    </div>
    <div class="flex gap-2">
      <%= submit_tag t("products.index.apply_filters"), class: "cursor-pointer rounded-md bg-stone-900 px-4 py-2 text-sm font-medium text-white hover:bg-stone-800" %>
      <%= link_to t("products.index.reset_filters"), products_path, class: "inline-flex items-center rounded-md border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-700 hover:bg-stone-50" %>
    </div>
  <% end %>

  <%= render "products/grid", products: @products %>
</div>
