<% content_for :title, t("products.index.title") %>

<div class="max-w-6xl">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <%= link_to t("categories.index.heading"), categories_path %>
    <span class="mx-2 text-ink-subtle" aria-hidden="true">/</span>
    <span class="font-medium text-ink"><%= t("products.index.heading") %></span>
  </nav>

  <h1 class="mt-4 section-heading-lg"><%= t("products.index.heading") %></h1>
  <p class="section-lead"><%= t("products.index.intro") %></p>

  <%= form_with url: products_path, method: :get, data: { turbo_frame: "products" }, class: "mt-8 flex flex-col gap-4 rounded-2xl border border-border bg-surface-card p-4 shadow-card sm:flex-row sm:flex-wrap sm:items-end" do %>
    <div class="flex min-w-0 flex-1 flex-col gap-1 sm:min-w-[12rem]">
      <%= label_tag :category_id, t("products.index.filter_category"), class: "form-label mt-0" %>
      <%= select_tag :category_id,
            options_for_select(
              [[t("products.index.any_category"), ""]] + @filter_categories.flat_map { |c|
                [[c.display_name, c.id.to_s]] + c.children.ordered.map { |ch| ["— #{ch.display_name}", ch.id.to_s] }
              },
              params[:category_id]
            ),
            class: "form-control mt-0" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= label_tag :min_price, t("products.index.filter_min_price"), class: "form-label mt-0" %>
      <%= number_field_tag :min_price, params[:min_price], min: 0, step: 0.01, class: "form-control mt-0 sm:w-36" %>
    </div>
    <div class="flex flex-col gap-1">
      <%= label_tag :max_price, t("products.index.filter_max_price"), class: "form-label mt-0" %>
      <%= number_field_tag :max_price, params[:max_price], min: 0, step: 0.01, class: "form-control mt-0 sm:w-36" %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= submit_tag t("products.index.apply_filters"), class: "btn-primary cursor-pointer border-0" %>
      <%= link_to t("products.index.reset_filters"), products_path, data: { turbo_frame: "products", turbo_action: "advance" }, class: "btn-secondary" %>
    </div>
  <% end %>

  <%= render "products/index_frame" %>
</div>
