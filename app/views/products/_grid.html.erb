<section class="mt-10" aria-label="<%= t('categories.show.products_heading') %>">
  <% if products.any? %>
    <h2 class="sr-only"><%= t("categories.show.products_heading") %></h2>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      <% products.each do |product| %>
        <article class="rounded-lg border border-stone-200 bg-white p-4 shadow-sm">
          <p class="text-sm text-stone-600"><%= t("products.card_placeholder") %></p>
          <p class="mt-1 text-xs text-stone-400">#<%= product.id %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="text-stone-500"><%= t("categories.empty_products") %></p>
  <% end %>
</section>
