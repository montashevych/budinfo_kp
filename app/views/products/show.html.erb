<% content_for :title, @product.display_title %>
<% content_for :meta_description, truncate(strip_tags(@product.display_description.to_s), length: 160) if @product.display_description.present? %>
<% content_for :head do %>
  <%= tag.meta name: "turbo-cache-control", content: "no-cache" %>
<% end %>

<div class="max-w-6xl">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <%= link_to t("categories.index.heading"), categories_path %>
    <span class="mx-2 text-ink-subtle" aria-hidden="true">/</span>
    <%= link_to @product.category.display_name, category_path(@product.category) %>
    <span class="mx-2 text-ink-subtle" aria-hidden="true">/</span>
    <span class="font-medium text-ink"><%= @product.display_title %></span>
  </nav>

  <div class="mt-8 grid gap-10 lg:grid-cols-2">
    <div>
      <% if @product.images.attached? %>
        <div class="space-y-4">
          <% @product.images.each do |image| %>
            <div class="aspect-square w-full overflow-hidden rounded-xl border border-border bg-surface-muted">
              <%= image_tag product_variant_image_path(image, [800, 800]),
                    class: "h-full w-full object-contain",
                    loading: "eager",
                    decoding: "async",
                    alt: @product.display_title %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex aspect-square items-center justify-center rounded-xl border border-dashed border-border-strong bg-surface-muted text-sm text-ink-subtle">
          <%= t("products.no_image") %>
        </div>
      <% end %>
    </div>

    <div>
      <h1 class="section-heading-lg"><%= @product.display_title %></h1>
      <p class="mt-4 text-3xl font-bold text-brand"><%= product_price(@product) %></p>

      <% if @product.stock.positive? %>
        <p class="mt-2 text-sm text-ink-muted"><%= t("products.in_stock", count: @product.stock) %></p>
      <% else %>
        <p class="mt-2 text-sm font-medium text-amber-800"><%= t("products.out_of_stock") %></p>
      <% end %>

      <% if @product.sku.present? %>
        <p class="mt-4 text-sm text-ink-muted"><span class="font-medium text-ink"><%= t("products.sku") %>:</span> <%= @product.sku %></p>
      <% end %>

      <div class="mt-6 max-w-sm">
        <%= render "products/add_to_cart", product: @product %>
      </div>

      <% if @product.display_description.present? %>
        <div class="mt-8 whitespace-pre-wrap border-t border-border pt-8 text-ink-muted leading-relaxed">
          <%= @product.display_description %>
        </div>
      <% end %>
    </div>
  </div>
</div>
