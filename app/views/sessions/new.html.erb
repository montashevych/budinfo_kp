<div class="mx-auto w-full max-w-md">
  <div class="auth-panel">
    <% if alert = flash[:alert] %>
      <p class="mb-5 inline-block rounded-lg bg-red-50 px-3 py-2 text-sm font-medium text-red-700" id="alert"><%= alert %></p>
    <% end %>

    <% if notice = flash[:notice] %>
      <p class="mb-5 inline-block rounded-lg bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-800" id="notice"><%= notice %></p>
    <% end %>

    <h1 class="section-heading-lg"><%= t("auth.sessions.title") %></h1>

    <%= form_with url: session_url, class: "mt-6 space-y-5" do |form| %>
      <div>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              placeholder: t("auth.sessions.email_placeholder"), value: params[:email_address],
              class: "form-control mt-0" %>
      </div>
      <div>
        <%= form.password_field :password, required: true, autocomplete: "current-password",
              placeholder: t("auth.sessions.password_placeholder"), maxlength: 72,
              class: "form-control mt-0" %>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <%= form.submit t("auth.sessions.submit"), class: "btn-primary cursor-pointer border-0" %>
        <%= link_to t("auth.sessions.forgot_password"), new_password_path, class: "text-sm font-medium text-ink-muted transition hover:text-brand" %>
      </div>
    <% end %>

    <p class="mt-8 text-sm text-ink-muted">
      <%= t("auth.sessions.no_account") %>
      <%= link_to t("nav.sign_up"), new_registration_path, class: "ml-1 font-semibold text-brand transition hover:text-brand-hover" %>
    </p>
  </div>
</div>
