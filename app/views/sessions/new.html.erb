<div class="mx-auto w-full max-w-md">
  <% if alert = flash[:alert] %>
    <p class="mb-5 inline-block rounded-lg bg-red-50 px-3 py-2 font-medium text-red-600" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="mb-5 inline-block rounded-lg bg-emerald-50 px-3 py-2 font-medium text-emerald-800" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="text-3xl font-bold tracking-tight text-stone-900"><%= t("auth.sessions.title") %></h1>

  <%= form_with url: session_url, class: "mt-6 space-y-5" do |form| %>
    <div>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
            placeholder: t("auth.sessions.email_placeholder"), value: params[:email_address],
            class: "mt-1 block w-full rounded-md border border-stone-300 px-3 py-2 shadow-sm focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500" %>
    </div>
    <div>
      <%= form.password_field :password, required: true, autocomplete: "current-password",
            placeholder: t("auth.sessions.password_placeholder"), maxlength: 72,
            class: "mt-1 block w-full rounded-md border border-stone-300 px-3 py-2 shadow-sm focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500" %>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <%= form.submit t("auth.sessions.submit"),
            class: "rounded-md bg-stone-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-500 focus:ring-offset-2" %>
      <%= link_to t("auth.sessions.forgot_password"), new_password_path, class: "text-sm text-stone-600 underline hover:text-stone-900" %>
    </div>
  <% end %>

  <p class="mt-8 text-sm text-stone-600">
    <%= t("auth.sessions.no_account") %>
    <%= link_to t("nav.sign_up"), new_registration_path, class: "ml-1 font-medium text-stone-900 underline" %>
  </p>
</div>
