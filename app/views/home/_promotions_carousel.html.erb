<%# locals: (promotions:) %>
<% return if promotions.blank? %>

<% multi = promotions.size > 1 %>

<%= tag.section(
  class: "mb-10 w-full max-w-5xl outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50",
  data: {
    controller: "promotion-carousel",
    promotion_carousel_interval_ms_value: 10_000
  },
  aria: {
    label: t("home.promotions.region_label"),
    roledescription: t("home.promotions.carousel_role"),
    labelledby: "home-promotions-heading"
  }
) do %>
  <h2 id="home-promotions-heading" class="sr-only"><%= t("home.promotions.heading") %></h2>

  <p id="home-promotions-live" class="sr-only" aria-live="polite" aria-atomic="true" data-promotion-carousel-target="live"></p>

  <%# Fixed 16∶9 viewport — every slide uses the same outer box; arrows sit on the image with opacity. %>
  <div class="relative overflow-hidden rounded-xl border border-stone-200 bg-stone-900 shadow-md ring-1 ring-black/5">
    <% if multi %>
      <div
        class="pointer-events-none absolute inset-0 z-30 flex items-center justify-between px-1 sm:px-2"
        role="group"
        aria-label="<%= t("home.promotions.controls_label") %>">
        <button
          type="button"
          class="pointer-events-auto inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/30 bg-white/35 text-stone-900 shadow-sm backdrop-blur-sm transition hover:border-white/50 hover:bg-white/55 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:h-12 sm:w-12"
          data-promotion-carousel-target="prev"
          data-action="click->promotion-carousel#prev"
          aria-label="<%= t("home.promotions.prev_slide") %>">
          <svg class="h-5 w-5 opacity-90 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button
          type="button"
          class="pointer-events-auto inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/30 bg-white/35 text-stone-900 shadow-sm backdrop-blur-sm transition hover:border-white/50 hover:bg-white/55 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:h-12 sm:w-12"
          data-promotion-carousel-target="next"
          data-action="click->promotion-carousel#next"
          aria-label="<%= t("home.promotions.next_slide") %>">
          <svg class="h-5 w-5 opacity-90 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    <% end %>

    <% promotions.each_with_index do |promo, index| %>
      <%= tag.div(
        class: class_names("hidden" => multi && index.positive?),
        data: {
          promotion_carousel_target: "slide",
          carousel_title: promo.title
        },
        **(multi && index.positive? ? { aria: { hidden: true } } : {})
      ) do %>
        <%= link_to promotion_path(promo),
              class: "group relative block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" do %>
          <%# Fixed 16∶9 box (custom utility — aspect-video is not always present in built Tailwind CSS). %>
          <div class="home-promo-media-box bg-stone-800">
            <% if promo.image.attached? %>
              <%= image_tag product_variant_image_path(promo.image, [1280, 720]),
                    class: "absolute inset-0 z-0 h-full w-full object-cover object-center transition duration-500 ease-out group-hover:scale-[1.03]",
                    loading: (index.zero? ? "eager" : "lazy"),
                    decoding: "async",
                    alt: "" %>
            <% else %>
              <div class="absolute inset-0 flex items-center justify-center bg-stone-700 text-sm text-stone-400">
                <%= t("products.no_image_short") %>
              </div>
            <% end %>

            <%# Bottom caption: semi-opaque frame over the image %>
            <div class="absolute inset-x-0 bottom-0 z-10 border-t border-white/15 bg-stone-950/60 px-4 py-3 backdrop-blur-md sm:px-5 sm:py-4">
              <p class="text-base font-semibold leading-snug tracking-tight text-white drop-shadow-sm line-clamp-2 sm:text-lg">
                <%= promo.title %>
              </p>
              <% if promo.teaser.present? %>
                <p class="mt-1.5 text-sm leading-relaxed text-white/90 line-clamp-2 drop-shadow-sm">
                  <%= promo.teaser %>
                </p>
              <% end %>
              <p class="mt-2.5 text-sm font-medium text-white underline decoration-white/70 underline-offset-4 group-hover:decoration-white">
                <%= t("home.promotions.read_more") %>
              </p>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
