<%# locals: (promotions:) %>
<% return if promotions.blank? %>

<% urls_json = promotions.map { |p| promotion_path(p) }.to_json %>

<%= tag.section(
  class: "mb-10",
  data: {
    controller: "promotion-carousel",
    promotion_carousel_count_value: promotions.size,
    promotion_carousel_urls_value: urls_json
  },
  aria: { label: t("home.promotions.region_label"), roledescription: t("home.promotions.carousel_role") }
) do %>
  <h2 class="sr-only"><%= t("home.promotions.heading") %></h2>
  <div class="space-y-8">
    <% promotions.each do |promo| %>
      <%= link_to promotion_path(promo),
            class: "group block overflow-hidden rounded-xl border border-stone-200 bg-white shadow-sm transition hover:border-stone-300 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-900" do %>
        <% if promo.image.attached? %>
          <div class="aspect-[16/9] w-full overflow-hidden bg-stone-100">
            <%= image_tag product_variant_image_path(promo.image, [960, 540]),
                  class: "h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]",
                  loading: "lazy",
                  decoding: "async",
                  alt: promo.title %>
          </div>
        <% end %>
        <div class="px-4 py-4 sm:px-5 sm:py-5">
          <p class="text-lg font-semibold tracking-tight text-stone-900 group-hover:text-stone-700"><%= promo.title %></p>
          <% if promo.teaser.present? %>
            <p class="mt-2 text-sm leading-relaxed text-stone-600"><%= promo.teaser %></p>
          <% end %>
          <p class="mt-3 text-sm font-medium text-stone-800 underline decoration-stone-300 underline-offset-4 group-hover:decoration-stone-500">
            <%= t("home.promotions.read_more") %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
