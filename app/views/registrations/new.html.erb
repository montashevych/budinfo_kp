<div class="mx-auto w-full max-w-md">
  <div class="auth-panel">
    <h1 class="section-heading-lg"><%= t("auth.registration.title") %></h1>

    <%= form_with model: @user, url: registration_path, class: "mt-6 space-y-5" do |form| %>
      <% if @user.errors.any? %>
        <ul class="rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
      <div>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              placeholder: t("auth.sessions.email_placeholder"),
              class: "form-control mt-0" %>
      </div>
      <div>
        <%= form.password_field :password, required: true, autocomplete: "new-password",
              placeholder: t("auth.sessions.password_placeholder"), maxlength: 72,
              class: "form-control mt-0" %>
      </div>
      <div>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
              placeholder: t("auth.registration.password_confirmation_placeholder"), maxlength: 72,
              class: "form-control mt-0" %>
      </div>
      <%= form.submit t("auth.registration.submit"), class: "w-full btn-primary cursor-pointer border-0 sm:w-auto" %>
    <% end %>

    <p class="mt-8 text-sm text-ink-muted">
      <%= t("auth.registration.has_account") %>
      <%= link_to t("nav.sign_in"), new_session_path, class: "ml-1 font-semibold text-brand transition hover:text-brand-hover" %>
    </p>
  </div>
</div>
