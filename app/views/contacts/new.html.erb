<div class="max-w-6xl">
  <h1 class="section-heading-lg"><%= t("contacts.heading") %></h1>
  <p class="section-lead"><%= t("contacts.placeholder") %></p>

  <%= form_with url: contacts_path, method: :post, class: "card mt-8 space-y-5 p-6" do |f| %>
    <div>
      <%= f.label :email, t("contacts.email_label"), class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true, autocomplete: "email" %>
    </div>
    <div>
      <%= f.label :message, t("contacts.message_label"), class: "form-label" %>
      <%= f.text_area :message, rows: 4, class: "form-control" %>
    </div>
    <%= f.submit t("contacts.submit"), class: "btn-primary cursor-pointer border-0" %>
  <% end %>
</div>
