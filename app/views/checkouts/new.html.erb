<% content_for :title, t("checkouts.title") %>

<div class="max-w-6xl">
  <h1 class="section-heading-md"><%= t("checkouts.heading") %></h1>
  <p class="section-lead-tight max-w-2xl"><%= t("checkouts.intro") %></p>

  <div class="mt-8 grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-2 card p-5">
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink-subtle"><%= t("checkouts.summary") %></h2>
      <ul class="mt-4 space-y-2 text-sm text-ink-muted">
        <% @line_items.each do |line| %>
          <li class="flex justify-between gap-2">
            <span class="min-w-0 truncate"><%= line.product.display_title %> × <%= line.quantity %></span>
            <span class="shrink-0 tabular-nums font-medium text-ink"><%= number_to_currency(line.quantity * line.product.price, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></span>
          </li>
        <% end %>
      </ul>
      <p class="mt-4 border-t border-border pt-4 text-sm font-bold text-ink">
        <%= t("carts.total") %>: <%= number_to_currency(current_cart.total, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %>
      </p>
    </div>

    <div class="lg:col-span-3">
      <%= form_with model: @order, url: checkout_path, method: :post, class: "space-y-5" do |f| %>
        <div>
          <%= f.label :email, t("checkouts.email"), class: "form-label" %>
          <%= f.email_field :email, required: true, autocomplete: "email", class: "form-control" %>
          <% @order.errors.full_messages_for(:email).each do |msg| %>
            <p class="form-error"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_name, t("checkouts.shipping_name"), class: "form-label" %>
          <%= f.text_field :shipping_name, required: true, autocomplete: "name", class: "form-control" %>
          <% @order.errors.full_messages_for(:shipping_name).each do |msg| %>
            <p class="form-error"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_phone, t("checkouts.shipping_phone"), class: "form-label" %>
          <%= f.telephone_field :shipping_phone, required: true, autocomplete: "tel", class: "form-control" %>
          <% @order.errors.full_messages_for(:shipping_phone).each do |msg| %>
            <p class="form-error"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_address, t("checkouts.shipping_address"), class: "form-label" %>
          <%= f.text_area :shipping_address, required: true, rows: 4, class: "form-control" %>
          <% @order.errors.full_messages_for(:shipping_address).each do |msg| %>
            <p class="form-error"><%= msg %></p>
          <% end %>
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          <%= f.submit t("checkouts.submit"), class: "btn-primary cursor-pointer border-0" %>
          <%= link_to t("checkouts.back_to_cart"), cart_path, class: "btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
