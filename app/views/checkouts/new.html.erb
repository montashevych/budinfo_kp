<% content_for :title, t("checkouts.title") %>

<div class="max-w-3xl">
  <h1 class="text-2xl font-semibold tracking-tight text-stone-900"><%= t("checkouts.heading") %></h1>
  <p class="mt-2 text-sm text-stone-600"><%= t("checkouts.intro") %></p>

  <div class="mt-8 grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-2 rounded-lg border border-stone-200 bg-white p-4">
      <h2 class="text-sm font-semibold text-stone-900"><%= t("checkouts.summary") %></h2>
      <ul class="mt-3 space-y-2 text-sm text-stone-700">
        <% @line_items.each do |line| %>
          <li class="flex justify-between gap-2">
            <span class="min-w-0 truncate"><%= line.product.display_title %> × <%= line.quantity %></span>
            <span class="shrink-0 tabular-nums"><%= number_to_currency(line.quantity * line.product.price, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %></span>
          </li>
        <% end %>
      </ul>
      <p class="mt-4 border-t border-stone-100 pt-3 text-sm font-semibold text-stone-900">
        <%= t("carts.total") %>: <%= number_to_currency(current_cart.total, unit: "₴", format: "%n %u", separator: ",", delimiter: " ") %>
      </p>
    </div>

    <div class="lg:col-span-3">
      <%= form_with model: @order, url: checkout_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, t("checkouts.email"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.email_field :email, required: true, autocomplete: "email", class: "mt-1 w-full rounded-md border border-stone-300 px-3 py-2 text-sm" %>
          <% @order.errors.full_messages_for(:email).each do |msg| %>
            <p class="mt-1 text-sm text-red-700"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_name, t("checkouts.shipping_name"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :shipping_name, required: true, autocomplete: "name", class: "mt-1 w-full rounded-md border border-stone-300 px-3 py-2 text-sm" %>
          <% @order.errors.full_messages_for(:shipping_name).each do |msg| %>
            <p class="mt-1 text-sm text-red-700"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_phone, t("checkouts.shipping_phone"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.telephone_field :shipping_phone, required: true, autocomplete: "tel", class: "mt-1 w-full rounded-md border border-stone-300 px-3 py-2 text-sm" %>
          <% @order.errors.full_messages_for(:shipping_phone).each do |msg| %>
            <p class="mt-1 text-sm text-red-700"><%= msg %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :shipping_address, t("checkouts.shipping_address"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_area :shipping_address, required: true, rows: 4, class: "mt-1 w-full rounded-md border border-stone-300 px-3 py-2 text-sm" %>
          <% @order.errors.full_messages_for(:shipping_address).each do |msg| %>
            <p class="mt-1 text-sm text-red-700"><%= msg %></p>
          <% end %>
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          <%= f.submit t("checkouts.submit"), class: "rounded-md border border-stone-800 bg-stone-900 px-4 py-2 text-sm font-medium text-white hover:bg-stone-800" %>
          <%= link_to t("checkouts.back_to_cart"), cart_path, class: "inline-flex items-center rounded-md border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-800 hover:bg-stone-50" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
