#!/bin/bash -e

# Thruster defaults HTTP_PORT=80; Cloud Run requires listening on $PORT (e.g. 8080).
export HTTP_PORT="${HTTP_PORT:-${PORT:-80}}"

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  if [ "${RAILS_ENV:-}" = "production" ] && [ -z "${DATABASE_URL:-}" ]; then
    echo "ERROR: DATABASE_URL is not set in this container." >&2
    echo "Rails would use a local Postgres socket and fail on Cloud Run." >&2
    echo "Fix: Cloud Run → service → Variables and secrets → add DATABASE_URL (Cloud SQL socket or TCP URL)." >&2
    echo "Also attach the Cloud SQL instance under Connections. See .env.example (Cloud Run + Cloud SQL)." >&2
    exit 1
  fi
  ./bin/rails db:prepare
fi

exec "${@}"
