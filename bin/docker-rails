#!/usr/bin/env sh
# Run bin/rails inside the web container (Docker Compose). Requires `db` healthy.
# Test-related tasks use RAILS_ENV=test and DATABASE_URL for app_test (see README).
set -e
ROOT="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

TEST_URL="${DOCKER_TEST_DATABASE_URL:-postgres://budinfo:budinfo_dev_password@db:5432/app_test}"

case "${1-}" in
  test|test:*|db:test:*)
    exec docker compose run --rm \
      -e RAILS_ENV=test \
      -e DATABASE_URL="$TEST_URL" \
      web bin/rails "$@"
    ;;
  *)
    exec docker compose run --rm web bin/rails "$@"
    ;;
esac
